{
  "name": "secretscan",
  "version": "1.0.0",
  "description": "Pre-commit secret scanner for AI agents — detects leaked credentials, API keys, and tokens in staged or tracked files before they reach the remote.",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "bin": {
    "secretscan": "dist/cli.js"
  },
  "files": [
    "dist/lib",
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "llm",
    "mcp",
    "secrets",
    "security",
    "pre-commit",
    "leaked-credentials",
    "developer-tools"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.3"
  }
}
