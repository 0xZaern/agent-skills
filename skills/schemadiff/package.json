{
  "name": "schemadiff",
  "version": "1.0.0",
  "description": "Token-efficient database schema digest for AI agents — reads Prisma, SQL DDL, or Drizzle schemas and returns a compact ERD-style digest with entities, fields, relations, and indexes",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "bin": {
    "schemadiff": "dist/cli.js"
  },
  "files": [
    "dist/lib",
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "llm",
    "mcp",
    "prisma",
    "drizzle",
    "sql",
    "schema",
    "database",
    "context",
    "developer-tools"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.3"
  }
}
