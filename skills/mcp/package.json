{
  "name": "agent-tools-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing agent-tools (devpulse, codemap) as native tools for MCP-compatible editors and AI workflows",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "agent-tools-mcp": "dist/server.js"
  },
  "files": [
    "dist/server.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "devpulse",
    "codemap",
    "developer-tools"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "codemap": "file:../codemap",
    "devpulse": "file:../devpulse"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.3"
  }
}
