{
  "name": "codemap",
  "version": "1.0.0",
  "description": "Token-efficient local codebase map for AI agents and LLMs — structure, exports, and signatures without the noise",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "bin": {
    "codemap": "dist/cli.js"
  },
  "files": [
    "dist/lib",
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "llm",
    "mcp",
    "codebase",
    "codemap",
    "symbols",
    "typescript",
    "context",
    "developer-tools"
  ],
  "dependencies": {
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
